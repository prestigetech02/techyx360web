NEXT_PUBLIC_SITE_URL=https://techyx360.com

# Supabase (Project Settings -> API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Server-only. Never expose this in the browser.
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Invoice email (Resend)
RESEND_API_KEY=your-resend-api-key
INVOICE_FROM_EMAIL=info@techyx360.com

# Google reCAPTCHA v3 (https://www.google.com/recaptcha/admin)
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=your-recaptcha-v3-site-key
RECAPTCHA_SECRET_KEY=your-recaptcha-v3-secret-key
# Optional minimum score between 0.0 and 1.0. Defaults to 0.5.
RECAPTCHA_MIN_SCORE=0.5
